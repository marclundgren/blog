---
---

<div class="theme-switcher">
	<details>
		<summary aria-label="Theme settings">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="4"/>
				<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
			</svg>
		</summary>

		<div class="panel">
			<div class="section">
				<span class="label">Mode</span>
				<div class="scheme-options">
					<button data-scheme="light" title="Light">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
						Light
					</button>
					<button data-scheme="auto" title="Auto">Auto</button>
					<button data-scheme="dark" title="Dark">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
						Dark
					</button>
				</div>
			</div>

			<div class="section">
				<span class="label">Theme</span>
				<div class="color-options">
					<button data-theme="default" class="swatch" style="--c: #2337ff" title="Default"></button>
					<button data-theme="ocean"   class="swatch" style="--c: #0891b2" title="Ocean"></button>
					<button data-theme="forest"  class="swatch" style="--c: #16a34a" title="Forest"></button>
					<button data-theme="rose"    class="swatch" style="--c: #e11d48" title="Rose"></button>
				</div>
			</div>
		</div>
	</details>
</div>

<script>
	const html = document.documentElement;

	function applyScheme(scheme: string) {
		html.dataset.scheme = scheme;
		localStorage.setItem('scheme', scheme);
		document.querySelectorAll('[data-scheme]').forEach((btn) => {
			(btn as HTMLElement).classList.toggle('active', (btn as HTMLElement).dataset.scheme === scheme);
		});
	}

	function applyTheme(theme: string) {
		html.dataset.theme = theme;
		localStorage.setItem('theme', theme);
		document.querySelectorAll('[data-theme]').forEach((btn) => {
			(btn as HTMLElement).classList.toggle('active', (btn as HTMLElement).dataset.theme === theme);
		});
	}

	// Initialize buttons to match current state
	applyScheme(localStorage.getItem('scheme') ?? 'auto');
	applyTheme(localStorage.getItem('theme') ?? 'default');

	// Wire up scheme buttons
	document.querySelectorAll<HTMLButtonElement>('.scheme-options [data-scheme]').forEach((btn) => {
		btn.addEventListener('click', () => applyScheme(btn.dataset.scheme!));
	});

	// Wire up theme swatches
	document.querySelectorAll<HTMLButtonElement>('.color-options [data-theme]').forEach((btn) => {
		btn.addEventListener('click', () => applyTheme(btn.dataset.theme!));
	});

	// Close panel when clicking outside
	document.addEventListener('click', (e) => {
		const switcher = document.querySelector('.theme-switcher details');
		if (switcher && !switcher.contains(e.target as Node)) {
			(switcher as HTMLDetailsElement).open = false;
		}
	});
</script>

<style>
	.theme-switcher {
		position: relative;
	}

	details {
		position: relative;
	}

	summary {
		list-style: none;
		cursor: pointer;
		padding: 0.4em;
		border-radius: 6px;
		color: rgb(var(--gray));
		display: flex;
		align-items: center;
		transition: color 0.2s;
	}
	summary::-webkit-details-marker { display: none; }
	summary:hover { color: rgb(var(--black)); }

	.panel {
		position: absolute;
		right: 0;
		top: calc(100% + 8px);
		background: rgb(var(--bg));
		border: 1px solid rgb(var(--gray-light));
		border-radius: 10px;
		padding: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 160px;
		box-shadow: var(--box-shadow);
		z-index: 100;
	}

	.section {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.label {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		font-weight: 700;
	}

	.scheme-options {
		display: flex;
		gap: 0.25rem;
	}

	.scheme-options button {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
		padding: 0.3rem 0.4rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		background: transparent;
		color: rgb(var(--gray-dark));
		font-size: 0.7rem;
		cursor: pointer;
		transition: all 0.15s;
	}
	.scheme-options button:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.scheme-options button.active {
		background: var(--accent);
		border-color: var(--accent);
		color: white;
	}

	.color-options {
		display: flex;
		gap: 0.4rem;
	}

	.swatch {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: var(--c);
		border: 2px solid transparent;
		cursor: pointer;
		transition: transform 0.15s, border-color 0.15s;
		outline: none;
	}
	.swatch:hover {
		transform: scale(1.15);
	}
	.swatch.active {
		border-color: rgb(var(--black));
		transform: scale(1.15);
	}
</style>
