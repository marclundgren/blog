---
---

<button class="theme-toggle" aria-label="Toggle light/dark mode">
	<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="4"/>
		<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
	</svg>
	<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
	</svg>
</button>

<script>
	const html = document.documentElement;
	const btn = document.querySelector('.theme-toggle')!;

	function isDark() {
		const scheme = localStorage.getItem('scheme');
		if (scheme === 'dark') return true;
		if (scheme === 'light') return false;
		return window.matchMedia('(prefers-color-scheme: dark)').matches;
	}

	function applyScheme(scheme: string) {
		html.dataset.scheme = scheme;
		localStorage.setItem('scheme', scheme);
		btn.setAttribute('aria-label', scheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
	}

	// Initialize
	applyScheme(localStorage.getItem('scheme') ?? 'auto');

	btn.addEventListener('click', () => {
		applyScheme(isDark() ? 'light' : 'dark');
	});
</script>

<style>
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4em;
		color: rgb(var(--gray));
		display: flex;
		align-items: center;
		border-radius: 6px;
		transition: color 0.2s;
	}
	.theme-toggle:hover {
		color: rgb(var(--black));
	}

	/* Show sun in dark mode, moon in light mode */
	.icon-sun { display: none; }
	.icon-moon { display: block; }

	:global(html[data-scheme="dark"]) .icon-sun { display: block; }
	:global(html[data-scheme="dark"]) .icon-moon { display: none; }

	@media (prefers-color-scheme: dark) {
		:global(html[data-scheme="auto"]) .icon-sun { display: block; }
		:global(html[data-scheme="auto"]) .icon-moon { display: none; }
	}
</style>
